def get_params():
    ''' parse command line '''
    import argparse
    description = 'fg-3D: 3D viewer for mesh and sol files'
    epilogue = '''
    lauch a graphic user interface to render magnetization from a feellgood .sol file as a vector field onto the
    corresponding mesh
    '''
    parser = argparse.ArgumentParser(description=description, epilog=epilogue, formatter_class=argparse.RawDescriptionHelpFormatter)
    parser.add_argument('meshFileName',nargs='?',
        help= """Optional mesh input file. If not provided fg-3D starts with some default parameters,
        and the user may open a gmsh mesh file from file menu""", 
        default=None)
    parser.add_argument('--version',action='version',version= __version__,help='show the version number')
    args = parser.parse_args()
    return args

def launchGUI(meshFileName):
    try:
        from PyQt5.QtWidgets import QApplication
        app = QApplication(sys.argv)
        window = CombinedInterface(meshFileName)
        window.show()
        sys.exit(app.exec_())
    finally:
        sys.exit()

def main():
    '''
    launch the parsing of the command line
    detect if on windows or unix-like platform
    On windows, try to launch the GUI, on unix-like, try to fix some environnment variables for
    nvidia GPU if any. Then it tries to launch the GUI if PyQt5 is available else exit
    '''
    args = get_params()
    if (os.name == "nt"):
        launchGUI(args.meshFileName)
    elif (os.name == "posix"):
        display = os.environ.get('DISPLAY') #might not run correctly on WayLand, see WAYLAND_DISPLAY environment variable
        if ((display == "") or (display is None)):
            print("Error: no display.")
            sys.exit()
        else:
            if has_nvidia_gpu():
                os.environ["__NV_PRIME_RENDER_OFFLOAD"] = "1"
                os.environ["__GLX_VENDOR_LIBRARY_NAME"] = "nvidia"
            else:
                print("Warning: no NVIDIA GPU detected.")
            launchGUI(args.meshFileName)

__version__ = '0.0.0'
if __name__ == "__main__":
    main()
