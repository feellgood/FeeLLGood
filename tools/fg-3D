def has_nvidia_gpu():
    ''' ask nvidia-smi if there is any nvidia GPU with proprietary driver, return true if any '''
    import subprocess
    try:
        subprocess.run(["nvidia-smi"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)
        return True
    except (subprocess.CalledProcessError, FileNotFoundError):
        return False

def load_sol_file(filename):
    """
    Load magnetization vectors from a .sol file.
    Returns a dictionary: node_index -> (mx, my, mz)
    """
    magnetization = {}
    try:
        with open(filename, 'r') as f:
            for line in f:
                line = line.strip()
                # Skip comments and empty lines
                if line.startswith('#') or not line:
                    continue
                
                # Parse data lines
                parts = line.split()
                if len(parts) >= 4:
                    try:
                        idx = int(parts[0])
                        mx = float(parts[1])
                        my = float(parts[2])
                        mz = float(parts[3])
                        magnetization[idx] = np.array([mx, my, mz])
                    except (ValueError, IndexError):
                        continue
        return magnetization
    except Exception as e:
        raise RuntimeError(f"❌ Error loading .sol file '{filename}': {e}")

def load_mesh(filename):
    """
    Load surfaces and related data from a gmsh file.
    Surfaces have to be composed of triangles, any other element is not considered.
    Returns a string message, surface node indices, point coordinates and triangular connectivity.
    This function loads nothing about tetrahedrons.
    Raises an error if the file does not exist or contains no triangles.
    """
    strLog = ""
    if not os.path.isfile(filename):
        raise FileNotFoundError(f"❌ The file '{filename}' does not exist.")
    try:
        mesh = meshio.read(filename)
        strLog += f"✓ mesh file '{filename}' loaded, "
        points = mesh.points[:, :3]
        triangles = []
        surface_nodes = set()
        for cell_block in mesh.cells:
            if cell_block.type == "triangle":
                triangles.append(cell_block.data)
                for tri in cell_block.data: # tri = triplet of node indices
                    surface_nodes.update(tri)
        if not triangles:
            strLog += f"✗ No triangles found in mesh '{filename}'."
            raise ValueError(f"❌ No triangles found in mesh '{filename}'.")
        triangles = np.vstack(triangles)
        strLog += str(len(triangles)) + " triangles"
        return strLog, surface_nodes, points, triangles
    except Exception as e:
        raise RuntimeError(f"❌ Error while loading mesh '{filename}': {e}")

def avg_m(m_list,triangle):
    ''' returns normed average magnetization of the triangle '''
    i = triangle[0]
    j = triangle[1]
    k = triangle[2]
    m = (m_list[i] + m_list[j] + m_list[k])/3.0
    return m/np.linalg.norm(m)

def compute_surf_charges(m,triangles,n):
    ''' m is the magnetization list on the nodes, triangles the triangle list, n the list of the normal of the triangles
    returns surface charges
    '''
    dot_m_n = np.empty(shape=len(n), dtype=float)
    if len(triangles) == len(n):
        for i in np.arange(len(n)):
            normed_n = n[i]/np.linalg.norm(n[i])
            dot_m_n[i] = np.dot(avg_m(m,triangles[i]),normed_n)
    return dot_m_n

def create_pyvista_mesh(points, triangles):
    ''' return pyvista triangles '''
    faces = np.hstack([np.full((triangles.shape[0], 1), 3), triangles]).astype(np.int32)
    return pv.PolyData(points, faces)

